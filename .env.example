# App connects as the non-owner gemplots_app role (audit immutability has teeth)
DATABASE_URL=postgres://gemplots_app:gemplots_app_dev@localhost:5432/gemplots
# Admin/owner connection used only by migrate + seed
DATABASE_URL_ADMIN=postgres://localhost:5432/gemplots
REDIS_URL=redis://localhost:6379
PORT=3000
WORKER_MODE=api                 # api | worker | all
NODE_ENV=development            # production refuses dev-default secrets (F5)

JWT_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
OTP_PEPPER=dev-otp-pepper-change-me

# Email (demo mode): console driver logs + records to emails_outbox; flip to smtp later
EMAIL_MODE=console              # console | smtp
# SMTP_HOST=  SMTP_PORT=587  SMTP_USER=  SMTP_PASS=  SMTP_FROM=noreply@gemhousing.in
ADMIN_ALERT_EMAIL=admin@gemhousing.in

# Storage (local disk): images written under UPLOADS_DIR, served at /files/*
STORAGE_MODE=local              # local | s3
UPLOADS_DIR=./uploads

# Payments are dormant (no gateway). Keep the tested code alive behind this flag.
PAYMENTS_ENABLED=false

PUBLIC_BASE_URL=https://plots.gemhousing.in
GLOBAL_HOLD_MINUTES=1440  MAX_ACTIVE_HOLDS=2

# --- later (commented until integrations go live) ---
# S3_ENDPOINT=  S3_BUCKET=  S3_KEY=  S3_SECRET=
# PAYMENT_GATEWAY=RAZORPAY  PG_KEY_ID=  PG_KEY_SECRET=  PG_WEBHOOK_SECRET=
# FCM_SERVER_KEY=  SMS_PROVIDER_KEY=  SMS_DLT_HEADER=
