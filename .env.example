# App connects as the non-owner dhanam_app role (audit immutability has teeth)
DATABASE_URL=postgres://dhanam_app:dhanam_app_dev@localhost:5432/dhanam
# Admin/owner connection used only by migrate + seed
DATABASE_URL_ADMIN=postgres://localhost:5432/dhanam
REDIS_URL=redis://localhost:6379
PORT=3000
WORKER_MODE=api                 # api | worker | all
JWT_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
OTP_PEPPER=dev-otp-pepper-change-me
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=dhanam-dev
S3_KEY=dev
S3_SECRET=devsecret
PAYMENT_GATEWAY=RAZORPAY
PG_KEY_ID=rzp_test_xxx
PG_KEY_SECRET=rzp_test_secret
PG_WEBHOOK_SECRET=whsec_dev
FCM_SERVER_KEY=
SMS_PROVIDER_KEY=
SMS_DLT_HEADER=DHANAM
GLOBAL_HOLD_MINUTES=1440
MAX_ACTIVE_HOLDS=2
